{
    "name": "spatie/mailcoach",
    "type": "project",
    "description": "Self-host Mailcoach",
    "keywords": [
        "mailcoach",
        "spatie"
    ],
    "repositories": [
        {
            "type": "composer",
            "url": "https://satis.spatie.be"
        },
        {
            "type": "vcs",
            "url": "https://github.com/laravel-shift/sidecar.git"
        },
        {
            "type": "package",
            "package": {
                "name": "spatie/mjml-sidecar",
                "version": "1.1.2",
                "description": "Compile MJML to HTML using Sidecar",
                "license": "MIT",
                "require": {
                    "php": "^8.1",
                    "hammerstone/sidecar": "^0.7",
                    "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
                    "spatie/laravel-package-tools": "^1.14.0",
                    "spatie/mjml-php": "^1.0"
                },
                "autoload": {
                    "psr-4": {
                        "Spatie\\MjmlSidecar\\": "src/",
                        "Spatie\\MjmlSidecar\\Database\\Factories\\": "database/factories/"
                    }
                },
                "dist": {
                    "type": "zip",
                    "url": "https://github.com/spatie/mjml-sidecar/archive/refs/tags/1.1.1.zip",
                    "reference": "1.1.1"
                }
            }
        }
    ],
    "require": {
        "php": "^8.3",
        "guzzlehttp/guzzle": "^7.9.2",
        "hammerstone/sidecar": "dev-l13-compatibility as 0.7.1",
        "laravel/framework": "^13.0",
        "laravel/horizon": "^5.31.0",
        "laravel/sanctum": "^4.0.8",
        "laravel/tinker": "^3.0",
        "laravel/ui": ">=4.6.1",
        "league/flysystem-aws-s3-v3": "^3.29",
        "spatie/laravel-mailcoach": "^10.0",
        "spatie/mjml-sidecar": "^1.1",
        "symfony/process": "^7.0.7"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24.1",
        "larastan/larastan": "^3.1.0",
        "laravel/boost": "^2.4",
        "laravel/pint": "^1.21",
        "laravel/sail": "^1.41.0",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.5",
        "phpunit/phpunit": "^12.0",
        "spatie/laravel-ignition": "^2.9.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan mailcoach:publish"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php -r \"rename('.gitignore.example', '.gitignore');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php artisan mailcoach:publish"
        ],
        "stan": "vendor/bin/phpstan analyse --memory-limit 4048M",
        "pint": "vendor/bin/pint -vvv"
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
